      <xs:element name="study_date" type="xs:string" minOccurs="0"/>
      <xs:element name="calcium_score" type="xs:string" minOccurs="0"/>
      <xs:element name="anatomical_notes" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MedicationsHeldType">
    <xs:sequence>
      <xs:element name="medication" type="MedicationHeldType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MedicationHeldType">
    <xs:sequence>
      <xs:element name="name" type="xs:string"/>
      <xs:element name="held_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="reason" type="xs:string" minOccurs="0"/>
      <xs:element name="bridging_therapy" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreoperativeInstructionsType">
    <xs:sequence>
      <xs:element name="nil_per_os_start" type="xs:string" minOccurs="0"/>
      <xs:element name="preoperative_antibiotic" type="xs:string" minOccurs="0"/>
      <xs:element name="skin_preparation" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="IntraOperativeType">
    <xs:sequence>
      <xs:element name="anesthesia" type="AnesthesiaType" minOccurs="0"/>
      <xs:element name="surgical_procedure" type="SurgicalProcedureType" minOccurs="0"/>
      <xs:element name="intraoperative_events" type="IntraoperativeEventsType" minOccurs="0"/>
      <xs:element name="fluid_management" type="FluidManagementType" minOccurs="0"/>
