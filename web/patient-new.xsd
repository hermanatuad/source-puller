      <xs:element name="monitoring_lines" type="MonitoringLinesType" minOccurs="0"/>
      <xs:element name="hemodynamic_parameters" type="HemodynamicParametersType" minOccurs="0"/>
      <xs:element name="intraoperative_medications" type="IntraoperativeMedicationsType" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MonitoringLinesType">
    <xs:sequence>
      <xs:element name="line" type="MonitoringLineType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

