<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="unqualified" attributeFormDefault="unqualified">

  <xs:element name="patients" type="PatientsType"/>

  <xs:complexType name="PatientsType">
    <xs:sequence>
      <xs:element name="demographics" type="DemographicsType"/>
      <xs:element name="episodes" type="EpisodesType"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DemographicsType">
    <xs:sequence>
      <xs:element name="patient_id" type="xs:string"/>
      <xs:element name="date_of_birth" type="xs:string"/>
      <xs:element name="medical_record_number" type="xs:string"/>
      <xs:element name="age_at_admission" type="xs:integer"/>
      <xs:element name="gender" type="xs:string"/>
      <xs:element name="ethnicity" type="xs:string"/>
      <xs:element name="primary_language" type="xs:string"/>
      <xs:element name="insurance_type" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ValueWithUnitType">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="unit" type="xs:string" use="optional"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="EpisodesType">
    <xs:sequence>
      <xs:element name="episode" type="EpisodeType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="EpisodeType">
    <xs:sequence>
      <xs:element name="episode_id" type="xs:string"/>
      <xs:element name="admission_info" type="AdmissionInfoType"/>
      <xs:element name="historical_risk_factors" type="HistoricalRiskFactorsType"/>
      <xs:element name="historical_medications" type="HistoricalMedicationsType"/>
      <xs:element name="episode_summary" type="EpisodeSummaryType"/>
      <xs:element name="stages" type="StagesType"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AdmissionInfoType">
    <xs:sequence>
      <xs:element name="admission_date" type="xs:string"/>
      <xs:element name="admission_source" type="xs:string"/>
      <xs:element name="presenting_complaint" type="xs:string"/>
      <xs:element name="admission_weight_kg" type="xs:decimal"/>
      <xs:element name="admission_height_cm" type="xs:decimal"/>
      <xs:element name="bmi" type="xs:decimal"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="HistoricalRiskFactorsType">
    <xs:sequence>
      <xs:element name="risk_factor" type="HistoricalRiskFactorType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="HistoricalRiskFactorType">
    <xs:sequence>
      <xs:element name="condition" type="xs:string"/>
      <xs:element name="diagnosis_date" type="xs:string"/>
      <xs:element name="status" type="xs:string"/>
      <xs:element name="notes" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="HistoricalMedicationsType">
    <xs:sequence>
      <xs:element name="medication" type="HistoricalMedicationType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="HistoricalMedicationType">
    <xs:sequence>
      <xs:element name="medication_name" type="xs:string"/>
      <xs:element name="dose" type="ValueWithUnitType"/>
      <xs:element name="frequency" type="xs:string"/>
      <xs:element name="route" type="xs:string"/>
      <xs:element name="start_date" type="xs:string"/>
      <xs:element name="end_date" type="xs:string" nillable="true" minOccurs="0"/>
      <xs:element name="status" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="EpisodeSummaryType">
    <xs:sequence>
      <xs:element name="total_length_of_stay_days" type="xs:decimal"/>
      <xs:element name="discharge_date" type="xs:string"/>
      <xs:element name="discharge_disposition" type="xs:string"/>
      <xs:element name="discharge_ambulatory_status" type="xs:string"/>
      <xs:element name="in_hospital_mortality" type="xs:boolean"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="StagesType">
    <xs:sequence>
      <xs:element name="stage" type="StageType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="StageType">
    <xs:all>
      <xs:element name="stage_type" type="xs:string" minOccurs="0"/>
      <xs:element name="stage_id" type="xs:string" minOccurs="0"/>
      <xs:element name="operation_sequence" type="xs:integer" minOccurs="0"/>
      <xs:element name="stage_sequence" type="xs:integer" minOccurs="0"/>
      <xs:element name="start_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="end_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="location" type="xs:string" minOccurs="0"/>
      <xs:element name="room_type" type="xs:string" minOccurs="0"/>
      <xs:element name="icu_acuity_level" type="xs:string" minOccurs="0"/>
      <xs:element name="icu_admission_source" type="xs:string" minOccurs="0"/>
      <xs:element name="clinical_assessments" type="ClinicalAssessmentsType" minOccurs="0"/>
      <xs:element name="diagnoses" type="DiagnosesType" minOccurs="0"/>
      <xs:element name="labs" type="LabsType" minOccurs="0"/>
      <xs:element name="ecg_findings" type="EcgFindingsType" minOccurs="0"/>
      <xs:element name="medications_administered" type="MedicationsAdministeredType" minOccurs="0"/>
      <xs:element name="risk_scores" type="RiskScoresType" minOccurs="0"/>
      <xs:element name="procedure_details" type="ProcedureDetailsType" minOccurs="0"/>
      <xs:element name="pre_operative_assessment" type="PreOperativeAssessmentType" minOccurs="0"/>
      <xs:element name="intra_operative" type="IntraOperativeType" minOccurs="0"/>
      <xs:element name="post_operative_handoff" type="PostOperativeHandoffType" minOccurs="0"/>
      <xs:element name="operative_note" type="OperativeNoteType" minOccurs="0"/>
      <xs:element name="quality_metrics" type="QualityMetricsType" minOccurs="0"/>
      <xs:element name="post_operative_diagnoses" type="PostOperativeDiagnosesType" minOccurs="0"/>
      <xs:element name="ventilator_management" type="VentilatorManagementType" minOccurs="0"/>
      <xs:element name="chest_tube_management" type="ChestTubeManagementType" minOccurs="0"/>
      <xs:element name="post_operative_complications" type="PostOperativeComplicationsType" minOccurs="0"/>
      <xs:element name="daily_goals" type="DailyGoalsType" minOccurs="0"/>
      <xs:element name="cardiac_rehabilitation" type="CardiacRehabilitationType" minOccurs="0"/>
      <xs:element name="patient_education" type="PatientEducationType" minOccurs="0"/>
      <xs:element name="discharge_planning" type="DischargePlanningType" minOccurs="0"/>
    </xs:all>
    <xs:attribute name="type" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ClinicalAssessmentsType">
    <xs:sequence>
      <xs:element name="assessment" type="AssessmentType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AssessmentType">
    <xs:sequence>
      <xs:element name="timestamp" type="xs:string" minOccurs="0"/>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element name="heart_rate" type="xs:string" minOccurs="0"/>
      <xs:element name="blood_pressure_systolic" type="xs:string" minOccurs="0"/>
      <xs:element name="blood_pressure_diastolic" type="xs:string" minOccurs="0"/>
      <xs:element name="oxygen_saturation" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="respiratory_rate" type="xs:string" minOccurs="0"/>
      <xs:element name="temperature_celsius" type="xs:string" minOccurs="0"/>
      <xs:element name="central_venous_pressure" type="xs:string" minOccurs="0"/>
      <xs:element name="pulmonary_artery_pressure_systolic" type="xs:string" minOccurs="0"/>
      <xs:element name="pulmonary_artery_pressure_diastolic" type="xs:string" minOccurs="0"/>
      <xs:element name="cardiac_output" type="xs:string" minOccurs="0"/>
      <xs:element name="pain_score" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="sedation_score" type="xs:string" minOccurs="0"/>
      <xs:element name="ambulation_distance_meters" type="xs:string" minOccurs="0"/>
      <xs:element name="dyspnea_on_exertion" type="xs:string" minOccurs="0"/>
      </xs:choice>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DiagnosesType">
    <xs:sequence>
      <xs:element name="diagnosis" type="DiagnosisType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DiagnosisType">
    <xs:sequence>
      <xs:element name="diagnosis_code" type="xs:string" minOccurs="0"/>
      <xs:element name="description" type="xs:string"/>
      <xs:element name="diagnosis_type" type="xs:string" minOccurs="0"/>
      <xs:element name="diagnosis_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="diagnosing_physician" type="xs:string" minOccurs="0"/>
      <xs:element name="status" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LabsType">
    <xs:sequence>
      <xs:element name="lab" type="LabType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LabType">
    <xs:sequence>
      <xs:element name="lab_type" type="xs:string"/>
      <xs:element name="lab_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="lab_value" type="xs:string" minOccurs="0"/>
      <xs:element name="lab_unit" type="xs:string" minOccurs="0"/>
      <xs:element name="reference_range" type="xs:string" minOccurs="0"/>
      <xs:element name="is_abnormal" type="xs:boolean" minOccurs="0"/>
      <xs:element name="hemoglobin" type="xs:string" minOccurs="0"/>
      <xs:element name="hematocrit" type="xs:string" minOccurs="0"/>
      <xs:element name="platelets" type="xs:string" minOccurs="0"/>
      <xs:element name="inr" type="xs:string" minOccurs="0"/>
      <xs:element name="ptt" type="xs:string" minOccurs="0"/>
      <xs:element name="creatinine" type="xs:string" minOccurs="0"/>
      <xs:element name="potassium" type="xs:string" minOccurs="0"/>
      <xs:element name="sodium" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="EcgFindingsType">
    <xs:sequence>
      <xs:element name="ecg_datetime" type="xs:string"/>
      <xs:element name="rhythm" type="xs:string"/>
      <xs:element name="findings" type="xs:string"/>
      <xs:element name="interpretation" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MedicationsAdministeredType">
    <xs:sequence>
      <xs:element name="medication" type="MedicationType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MedicationType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element name="medication_name" type="xs:string" minOccurs="0"/>
      <xs:element name="medication_class" type="xs:string" minOccurs="0"/>
      <xs:element name="name" type="xs:string" minOccurs="0"/>
      <xs:element name="dose" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="total_dose" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="frequency" type="xs:string" minOccurs="0"/>
      <xs:element name="route" type="xs:string" minOccurs="0"/>
      <xs:element name="administration_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="start_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="end_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="start_date" type="xs:string" minOccurs="0"/>
      <xs:element name="end_date" type="xs:string" nillable="true" minOccurs="0"/>
      <xs:element name="ordered_by" type="xs:string" minOccurs="0"/>
      <xs:element name="status" type="xs:string" minOccurs="0"/>
      <xs:element name="indication" type="xs:string" minOccurs="0"/>
      <xs:element name="weaning_notes" type="xs:string" minOccurs="0"/>
      <xs:element name="previous_dose" type="xs:string" minOccurs="0"/>
      <xs:element name="titration_reason" type="xs:string" minOccurs="0"/>
      <xs:element name="details" type="MedicationDetailsType" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="bridging_therapy" type="xs:string" minOccurs="0"/>
      <xs:element name="held_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="reason" type="xs:string" minOccurs="0"/>
      <xs:element name="act_target" type="xs:string" minOccurs="0"/>
      <xs:element name="act_achieved" type="xs:string" minOccurs="0"/>
      <xs:element name="post_act" type="xs:string" minOccurs="0"/>
      <xs:element name="procedure_type" type="xs:string" minOccurs="0"/>
      <xs:element name="procedure_code" type="xs:string" minOccurs="0"/>
      <xs:element name="access_site" type="xs:string" minOccurs="0"/>
      <xs:element name="sedation" type="xs:string" minOccurs="0"/>
      <xs:element name="performing_physician" type="xs:string" minOccurs="0"/>
      <xs:element name="lesion_treated" type="xs:string" minOccurs="0"/>
      <xs:element name="stent_type" type="xs:string" minOccurs="0"/>
      <xs:element name="stent_size" type="xs:string" minOccurs="0"/>
      <xs:element name="stent_count" type="xs:string" minOccurs="0"/>
      <xs:element name="procedural_success" type="xs:boolean" minOccurs="0"/>
      <xs:element name="complications" type="xs:string" minOccurs="0"/>
      <xs:element name="drug" type="xs:string" minOccurs="0"/>
      <xs:element name="ventilator_mode" type="xs:string" minOccurs="0"/>
      <xs:element name="fio2" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="peep" type="xs:string" minOccurs="0"/>
      <xs:element name="heart_rate" type="xs:string" minOccurs="0"/>
      <xs:element name="blood_pressure" type="xs:string" minOccurs="0"/>
      <xs:element name="central_venous_pressure" type="xs:string" minOccurs="0"/>
      <xs:element name="oxygen_saturation" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="rate" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="tidal_volume" type="xs:string" minOccurs="0"/>
      <xs:element name="removal_datetime" type="xs:string" minOccurs="0"/>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="MedicationDetailsType">
    <xs:sequence>
      <xs:element name="drug" type="xs:string"/>
      <xs:element name="dose" type="ValueWithUnitType" minOccurs="0"/>
      <xs:element name="frequency" type="xs:string" minOccurs="0"/>
      <xs:element name="route" type="xs:string" minOccurs="0"/>
      <xs:element name="start_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="status" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="RiskScoresType">
    <xs:sequence>
      <xs:element name="risk_score" type="RiskScoreType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="RiskScoreType">
    <xs:sequence>
      <xs:element name="score_type" type="xs:string"/>
      <xs:element name="score_value" type="xs:string"/>
      <xs:element name="risk_category" type="xs:string"/>
      <xs:element name="calculated_datetime" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ProcedureDetailsType">
    <xs:sequence>
      <xs:element name="procedure_type" type="xs:string"/>
      <xs:element name="procedure_code" type="xs:string"/>
      <xs:element name="access_site" type="xs:string" minOccurs="0"/>
      <xs:element name="sedation" type="xs:string" minOccurs="0"/>
      <xs:element name="performing_physician" type="xs:string" minOccurs="0"/>
      <xs:element name="angiography_findings" type="AngiographyFindingsType" minOccurs="0"/>
      <xs:element name="intervention" type="InterventionType" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AngiographyFindingsType">
    <xs:sequence>
      <xs:element name="coronary_dominance" type="xs:string" minOccurs="0"/>
      <xs:element name="left_main" type="xs:string" minOccurs="0"/>
      <xs:element name="left_anterior_descending" type="LeftAnteriorDescendingType" minOccurs="0"/>
      <xs:element name="ejection_fraction_visual" type="ValueWithUnitType" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LeftAnteriorDescendingType">
    <xs:sequence>
      <xs:element name="stenosis_percentage" type="xs:string" minOccurs="0"/>
      <xs:element name="location" type="xs:string" minOccurs="0"/>
      <xs:element name="lesion_characteristics" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="InterventionType">
    <xs:sequence>
      <xs:element name="lesion_treated" type="xs:string" minOccurs="0"/>
      <xs:element name="stent_type" type="xs:string" minOccurs="0"/>
      <xs:element name="stent_size" type="xs:string" minOccurs="0"/>
      <xs:element name="stent_count" type="xs:string" minOccurs="0"/>
      <xs:element name="procedural_success" type="xs:boolean" minOccurs="0"/>
      <xs:element name="complications" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreOperativeAssessmentType">
    <xs:sequence>
      <xs:element name="assessment_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="assessing_physician" type="xs:string" minOccurs="0"/>
      <xs:element name="preoperative_diagnoses" type="PreoperativeDiagnosesType" minOccurs="0"/>
      <xs:element name="planned_procedure" type="xs:string" minOccurs="0"/>
      <xs:element name="surgical_urgency" type="xs:string" minOccurs="0"/>
      <xs:element name="anesthesia_plan" type="xs:string" minOccurs="0"/>
      <xs:element name="preoperative_risk_assessment" type="PreoperativeRiskAssessmentType" minOccurs="0"/>
      <xs:element name="preoperative_labs" type="PreoperativeLabsType" minOccurs="0"/>
      <xs:element name="preoperative_imaging" type="PreoperativeImagingType" minOccurs="0"/>
      <xs:element name="medications_held" type="MedicationsHeldType" minOccurs="0"/>
      <xs:element name="preoperative_instructions" type="PreoperativeInstructionsType" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreoperativeDiagnosesType">
    <xs:sequence>
      <xs:element name="diagnosis" type="xs:string" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreoperativeRiskAssessmentType">
    <xs:sequence>
      <xs:element name="euroscore_ii" type="xs:string" minOccurs="0"/>
      <xs:element name="sts_mortality_risk" type="xs:string" minOccurs="0"/>
      <xs:element name="sts_morbidity_risk" type="xs:string" minOccurs="0"/>
      <xs:element name="asa_class" type="xs:string" minOccurs="0"/>
      <xs:element name="nyha_class" type="xs:string" minOccurs="0"/>
      <xs:element name="ccs_class" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreoperativeLabsType">
    <xs:sequence>
      <xs:element name="lab" type="PreoperativeLabType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreoperativeLabType">
    <xs:sequence>
      <xs:element name="lab_type" type="xs:string"/>
      <xs:element name="lab_datetime" type="xs:string" minOccurs="0"/>
      <xs:element name="hemoglobin" type="xs:string" minOccurs="0"/>
      <xs:element name="hematocrit" type="xs:string" minOccurs="0"/>
      <xs:element name="platelets" type="xs:string" minOccurs="0"/>
      <xs:element name="inr" type="xs:string" minOccurs="0"/>
      <xs:element name="ptt" type="xs:string" minOccurs="0"/>
      <xs:element name="creatinine" type="xs:string" minOccurs="0"/>
      <xs:element name="potassium" type="xs:string" minOccurs="0"/>
      <xs:element name="sodium" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PreoperativeImagingType">
    <xs:sequence>
      <xs:element name="echocardiogram" type="EchocardiogramType" minOccurs="0"/>
      <xs:element name="cardiac_ct" type="CardiacCtType" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="EchocardiogramType">
    <xs:sequence>
      <xs:element name="study_date" type="xs:string" minOccurs="0"/>
      <xs:element name="lvef_percentage" type="xs:string" minOccurs="0"/>
      <xs:element name="wall_motion_abnormalities" type="xs:string" minOccurs="0"/>
      <xs:element name="valvular_findings" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="CardiacCtType">
